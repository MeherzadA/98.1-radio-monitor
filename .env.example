# Copy this file to .env and fill in your own values.

# Create a bot with @BotFather on Telegram to get this token.
TELEGRAM_BOT_TOKEN=your_bot_token_here

# The chat ID Telegram alerts get sent to (your own user ID, or a group chat ID).
TELEGRAM_CHAT_ID=your_chat_id_here

# URL of the audio stream to monitor (HLS playlist or direct stream URL).
# Note: some stations issue session-specific URLs that expire - if the
# monitor stops being able to connect, grab a fresh URL.
STREAM_URL=https://example.com/stream/playlist.m3u8

# Full path to ffmpeg.exe, if it isn't already on your PATH.
FFMPEG_PATH=ffmpeg
